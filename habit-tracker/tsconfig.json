{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "strictNullChecks": true, 
    
    // Pro-Tip: It is usually better to just enable "strict" 
    // which includes strictNullChecks and other safety features
    "strict": true,
    
    "target": "ESNext",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
